{
    "name": "nicxonsolutions/laravel-rateable",
    "version": "1.0.0",
    "description": "Allows multiple models to be rated with a fivestar like system.",
    "keywords": [
        "laravel",
        "rateable",
        "rating",
        "vote",
        "fivestar",
        "laravel 8",
        "laravel 9",
        "laravel 10",
        "laravel 11",
        "laravel 12",
        "laravel 13"
    ],
    "homepage": "https://github.com/robertnicjoo/laravel-rateable",
    "license": "MIT",
    "authors": [
        {
            "name": "Nicxon Solutions",
            "email": "dev@nicxonsolutions.com",
            "homepage": "https://nicxonsolutions.com"
        }
    ],
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3 || ^8.4",
        "illuminate/support": "^8 || ^9 || ^10 || ^11 || ^12 || ^13",
        "illuminate/database": "^8.53 || ^9 || ^10 || ^11 || ^12 || ^13"
    },
    "require-dev": {
        "orchestra/testbench": "^6.23 || ^7 || ^8 || ^9 || ^10 || ^11",
        "phpunit/phpunit": "^9.5 || ^10.5 || ^11"
    },
    "autoload": {
        "psr-4": {
            "nicxonsolutions\\Rateable\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "nicxonsolutions\\Rateable\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "nicxonsolutions\\Rateable\\RateableServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}